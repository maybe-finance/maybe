<fieldset class="bg-gray-50 rounded-lg p-1 grid grid-flow-col justify-stretch gap-x-2">
  <% active_tab = local_assigns[:active_tab] || 'expense' %>

  <%= link_to new_account_transaction_path(nature: 'outflow'),
              data: { turbo_frame: :modal },
              class: "flex px-4 py-1 rounded-lg items-center space-x-2 justify-center text-subdued #{active_tab == 'expense' ? 'bg-white text-gray-800 shadow-sm' : 'hover:bg-white hover:text-gray-800 hover:shadow-sm'}" do %>
    <%= lucide_icon "minus-circle", class: "w-5 h-5" %>
    <%= tag.span t("shared.transaction_tabs.expense") %>
  <% end %>

  <%= link_to new_account_transaction_path(nature: 'inflow'),
              data: { turbo_frame: :modal },
              class: "flex px-4 py-1 rounded-lg items-center space-x-2 justify-center text-subdued #{active_tab == 'income' ? 'bg-white text-gray-800 shadow-sm' : 'hover:bg-white hover:text-gray-800 hover:shadow-sm'}" do %>
    <%= lucide_icon "plus-circle", class: "w-5 h-5" %>
    <%= tag.span t("shared.transaction_tabs.income") %>
  <% end %>

  <%= link_to new_transfer_path,
              data: { turbo_frame: :modal },
              class: "flex px-4 py-1 rounded-lg items-center space-x-2 justify-center text-subdued #{active_tab == 'transfer' ? 'bg-white text-gray-800 shadow-sm' : 'hover:bg-white hover:text-gray-800 hover:shadow-sm'}" do %>
    <%= lucide_icon "arrow-right-left", class: "w-5 h-5" %>
    <%= tag.span t("shared.transaction_tabs.transfer") %>
  <% end %>
</fieldset>